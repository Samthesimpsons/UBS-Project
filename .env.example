# LLM Configuration
GEMINI_API_KEY=your-gemini-api-key-here  # Required: obtain from https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash-lite       # Model identifier, change to gemini-2.5-pro for better quality

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot  # Async Postgres connection string
REDIS_URL=redis://localhost:6379/0                                          # Redis for mem0 short-context memory

# RAG / Vector Store
CHROMA_PERSIST_DIRECTORY=./data/chroma                       # Local ChromaDB storage path
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2  # HuggingFace model, auto-downloaded to models/
RAG_TOP_K=5                                                  # Number of chunks returned per similarity search

# Authentication
JWT_SECRET_KEY=change-me-to-a-secure-random-string  # Secret for signing JWT tokens, change in production
JWT_ALGORITHM=HS256                                 # JWT signing algorithm
JWT_EXPIRATION_MINUTES=60                           # Token validity duration

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# MCP Server URLs (Streamable HTTP endpoints)
# For local dev, point at the mock servers on ports 9001-9004
MCP_BANKING_OPS_URL=http://localhost:9001/mcp          # Wealth advisory, lending, banking ops
MCP_KNOWLEDGE_URL=http://localhost:9002/mcp            # Private banking, compliance, knowledge
MCP_SERVICE_WORKFLOW_URL=http://localhost:9003/mcp     # Client services, FX treasury, workflows
MCP_RAG_SERVER_URL=http://localhost:9004/mcp           # RAG document retrieval
